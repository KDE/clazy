#include <QtCore/QObject>
#include <QtCore/QString>
QString produceString()
{
    return "";
}
void testVarInitialization()
{
    QStringList myList{"abc", "xyz", "123"};
    QStringList myList2{"abc", "xyz"};
    QList<int> myList3{1, 2};
    QStringList myList4{"abc", "xyz", produceString()};
}

void consumeList(QStringList args)
{
    Q_UNUSED(args)
}

void testFunctionArgs()
{
    consumeList({"comsume", "meeee"});
}
void testWithComment()
{
    QStringList myList{"abc", // BLA
"xyz", // BLUB
};
    QStringList myList2{"abc" /*data1*/, "xyz" /*data2*/};
}

void testFromList()
{
    QStringList abc = QVector<QString>::fromList({"abc"}) << "xyz";
}
